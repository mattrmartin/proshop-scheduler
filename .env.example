# Supabase — proshop-scheduler project (NOT the golf-tracker project).
# Dashboard: Project Settings → Data API (URL) and API Keys.
# Copy this file to .env.local and fill in real values.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# Use the "publishable" key (sb_publishable_...) or legacy anon key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-PUBLISHABLE-OR-ANON-KEY

# Dev-only: set to show one-click "Sign in as … (dev)" buttons on /login that
# fill seeded users' real credentials. Leave all unset in production.
NEXT_PUBLIC_DEV_ADMIN_EMAIL=
NEXT_PUBLIC_DEV_ADMIN_PASSWORD=
NEXT_PUBLIC_DEV_STAFF_EMAIL=
NEXT_PUBLIC_DEV_STAFF_PASSWORD=
